# Copy this file to .env and fill in your values
# NEVER commit .env to git — it contains sensitive keys

# OpenAI API key (https://platform.openai.com/api-keys) — used for chatbot (gpt-4o-mini)
VITE_OPENAI_API_KEY=""

# Telegram Bot (https://t.me/BotFather)
VITE_TELEGRAM_BOT_TOKEN=""
VITE_TELEGRAM_CHAT_ID=""

# Supabase (optional — only if using edge functions)
# VITE_SUPABASE_URL=""
# VITE_SUPABASE_PUBLISHABLE_KEY=""

# Deployment (used by deploy.py — never commit real values)
DEPLOY_HOST=""
DEPLOY_USER="root"
DEPLOY_PASSWORD=""
