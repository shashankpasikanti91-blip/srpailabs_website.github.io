    {
      "parameters": {
        "jsCode": "const keyword = $input.first().json.Keyword || \"\";\nconst location = $input.first().json.Location || \"\";\nconst experiencelevel = $input.first().json[\"Experience Level\"] || \"\";\nconst remote = $input.first().json.Remote || \"\";\nconst jobtype = $input.first().json[\"Job Type\"] || \"\";\nconst easyApply = $input.first().json[\"Easy Apply\"] || \"\";\n\nconst encodedKeyword = encodeURIComponent(keyword);\nconst encodedLocation = encodeURIComponent(location);\n\nlet url = `https://www.linkedin.com/jobs/search/?f_TPR=r86400&refresh=true`;\n\nif (encodedKeyword !== \"\") {\n  url += `&keywords=${encodedKeyword}`;\n}\nif (encodedLocation !== \"\") {\n  url += `&location=${encodedLocation}`;\n}\nif (experiencelevel !== \"\") {\n  url += `&experiencelevel=${encodeURIComponent(experiencelevel)}`;\n}\nif (remote !== \"\") {\n  url += `&remote=${encodeURIComponent(remote)}`;\n}\nif (jobtype !== \"\") {\n  url += `&jobtype=${encodeURIComponent(jobtype)}`;\n}\nif (easyApply !== \"\") {\n  url += `&easyApply=${encodeURIComponent(easyApply)}`;\n}\n\nreturn { json: { url } };"
      },
